
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow read and write access to the projects collection
    // This allows for public viewing and admin management
    match /projects/{projectId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Default rule to deny everything else for security
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
