
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Re-triggering deployment to ensure projects collection is fully accessible
    // Allow public read/write access to the projects collection for MVP development
    match /projects/{document=**} {
      allow read, write: if true;
    }
    
    // Default rule to deny everything else for security
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
