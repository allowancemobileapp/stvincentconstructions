rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Deployment Trigger: 2024-05-24T14:45:00Z (Updated for fresh propagation)
    
    // Explicitly allow all read and write operations for the projects collection.
    // This is necessary for both the public view and the admin management features.
    match /projects/{document=**} {
      allow read, write: if true;
    }
    
    // Fallback rule for safety, while ensuring the primary collection is open.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
