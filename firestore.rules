
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicit global access to resolve persistent propagation issues.
    // Redeploy Trigger ID: FORCE_OPEN_ACCESS_2026_03_27_T21_10_00Z
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
