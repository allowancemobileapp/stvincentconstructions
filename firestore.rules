rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow all operations on the projects collection and all its documents.
    // Deployment Trigger: 2024-05-24T15:25:00Z (Force propagation)
    
    match /projects {
      allow read, write: if true;
    }

    match /projects/{projectId} {
      allow read, write: if true;
    }
    
    // Fallback for sub-collections if any
    match /projects/{document=**} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}