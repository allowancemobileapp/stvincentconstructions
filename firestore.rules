rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow all operations on the projects collection and all its documents.
    // This includes 'list' (collection) and 'get' (document) operations.
    // Deployment Trigger: 2024-05-24T18:45:00Z (Forced propagation)
    
    match /projects {
      allow read, write: if true;
    }

    match /projects/{projectId} {
      allow read, write: if true;
    }
    
    // Recursive match for any nested structures
    match /projects/{document=**} {
      allow read, write: if true;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}