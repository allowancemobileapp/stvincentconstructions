
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Deployment Trigger: 2024-05-24T10:30:00Z
    // Allow public read/write access to the projects collection for MVP development.
    // This allows the admin dashboard to manage listings and the public to view them.
    match /projects/{document=**} {
      allow read, write: if true;
    }
    
    // Default rule to deny everything else for security
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
