rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicit public access for the projects collection to resolve persistent propagation issues.
    // This allows both single document 'get' and collection 'list' operations.
    // Forced Redeploy Trigger: 2024-05-24T20:45:00Z
    
    match /projects/{projectId} {
      allow read, write: if true;
    }

    match /projects/{document=**} {
      allow read, write: if true;
    }

    // Default deny for everything else to maintain security on other potential paths.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}