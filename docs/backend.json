
{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A real estate project or property listing.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["For Sale", "For Rent", "Sold"] },
        "price": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "isFeatured": { "type": "boolean", "description": "Whether this project appears in the homepage hero carousel." },
        "features": { "type": "array", "items": { "type": "string" } },
        "thumbnail": {
          "type": "object",
          "properties": {
            "imageUrl": { "type": "string" },
            "description": { "type": "string" },
            "imageHint": { "type": "string" }
          }
        },
        "images": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "imageUrl": { "type": "string" },
              "description": { "type": "string" },
              "imageHint": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "price", "location", "description"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of property listings managed by the admin."
    }
  }
}
